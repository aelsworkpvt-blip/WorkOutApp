generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String             @id @default(cuid())
  name               String?
  age                Int?
  gender             Gender?
  heightCm           Float?
  currentWeightKg    Float?
  trainingMode       TrainingMode?
  splitPreference    SplitType?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  email              String?            @unique
  onboardingComplete Boolean            @default(false)
  hasSeenWelcomeCarousel Boolean        @default(false)
  passwordHash       String?
  measurements       MeasurementEntry[]
  nutritionTarget    NutritionTarget?
  goal               UserGoal?
  weeklyDigests      WeeklyDigest[]
  workoutSessions    WorkoutSession[]
}

model AccountDeletionRequest {
  id          String                       @id @default(cuid())
  email       String
  userId      String?
  reason      String?
  status      AccountDeletionRequestStatus @default(PENDING)
  requestedAt DateTime                     @default(now())
  resolvedAt  DateTime?

  @@index([email, requestedAt])
  @@index([status, requestedAt])
}

model UserGoal {
  id                  String          @id @default(cuid())
  userId              String          @unique
  goalType            GoalType
  activityLevel       ActivityLevel
  experienceLevel     ExperienceLevel
  targetWeightKg      Float?
  notes               String?
  weeklyWorkoutTarget Int             @default(5)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NutritionTarget {
  id              String   @id @default(cuid())
  userId          String   @unique
  calories        Int
  proteinG        Int
  carbsG          Int
  fatG            Int
  fiberG          Int
  hydrationLiters Float    @default(3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeasurementEntry {
  id         String   @id @default(cuid())
  userId     String
  recordedAt DateTime @default(now())
  weightKg   Float
  chestCm    Float?
  waistCm    Float?
  hipsCm     Float?
  armCm      Float?
  thighCm    Float?
  calfCm     Float?
  bodyFatPct Float?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
}

model WorkoutDayTemplate {
  id               String             @id @default(cuid())
  splitType        SplitType
  slug             String             @unique
  name             String
  focus            String
  accent           String
  description      String
  order            Int
  estimatedMinutes Int
  exercises        ExerciseTemplate[]
  sessions         WorkoutSession[]

  @@index([splitType, order])
}

model ExerciseTemplate {
  id            String             @id @default(cuid())
  dayTemplateId String
  slug          String             @unique
  name          String
  muscleGroup   MuscleGroup
  equipment     String
  instructions  String
  progressCue   String
  targetSets    Int
  repRangeMin   Int
  repRangeMax   Int
  restSeconds   Int
  order         Int
  exerciseLogs  ExerciseLog[]
  dayTemplate   WorkoutDayTemplate @relation(fields: [dayTemplateId], references: [id], onDelete: Cascade)

  @@index([dayTemplateId, order])
}

model WorkoutSession {
  id                      String             @id @default(cuid())
  userId                  String
  dayTemplateId           String
  performedAt             DateTime           @default(now())
  durationMin             Int
  estimatedCaloriesBurned Int
  totalVolumeKg           Float
  notes                   String?
  createdAt               DateTime           @default(now())
  exerciseLogs            ExerciseLog[]
  dayTemplate             WorkoutDayTemplate @relation(fields: [dayTemplateId], references: [id], onDelete: Cascade)
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, performedAt])
}

model ExerciseLog {
  id                 String           @id @default(cuid())
  sessionId          String
  exerciseTemplateId String
  setsCompleted      Int
  repsCompleted      Int
  weightKg           Float
  achievedMaxKg      Float?
  perceivedEffort    Int?
  notes              String?
  createdAt          DateTime         @default(now())
  exerciseTemplate   ExerciseTemplate @relation(fields: [exerciseTemplateId], references: [id], onDelete: Cascade)
  session            WorkoutSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([exerciseTemplateId, createdAt])
}

model WeeklyDigest {
  id                    String   @id @default(cuid())
  userId                String
  weekStart             DateTime
  workoutsCompleted     Int
  workoutTarget         Int
  totalVolumeKg         Float
  averageCaloriesBurned Int
  highlight             String
  focusForNextWeek      String
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum GoalType {
  FAT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  PERFORMANCE
}

enum AccountDeletionRequestStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum TrainingMode {
  MUSCLE_GROWTH
  FAT_LOSS
  BODY_RECOMPOSITION
}

enum SplitType {
  PPL
  BRO
}

enum ActivityLevel {
  LIGHT
  MODERATE
  HIGH
  ATHLETE
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  LEGS
  BICEPS
  TRICEPS
  GLUTES
  HAMSTRINGS
  QUADS
  CALVES
  CORE
  FULL_BODY
}
